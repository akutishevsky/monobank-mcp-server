{
    "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
    "name": "io.github.akutishevsky/monobank-mcp-server",
    "title": "Monobank",
    "description": "MCP server for Monobank API — currency rates, client info, and account statements",
    "websiteUrl": "https://github.com/akutishevsky/monobank-mcp-server#readme",
    "repository": {
        "url": "https://github.com/akutishevsky/monobank-mcp-server",
        "source": "github",
        "id": "akutishevsky/monobank-mcp-server"
    },
    "version": "1.2.0",
    "packages": [
        {
            "registryType": "npm",
            "registryBaseUrl": "https://registry.npmjs.org",
            "identifier": "monobank-mcp-server",
            "version": "1.2.0",
            "runtimeHint": "npx",
            "transport": {
                "type": "stdio"
            },
            "environmentVariables": [
                {
                    "name": "MONOBANK_API_TOKEN",
                    "description": "Monobank personal API token obtained from https://api.monobank.ua/",
                    "isRequired": true,
                    "isSecret": true
                }
            ]
        }
    ]
}
